PORT=4000

# Postgres (matches docker-compose.yml's postgres service)
DATABASE_URL=postgresql://cursive:cursive_dev_password@localhost:5432/cursive?schema=public

# Where the client dev server runs — used for CORS and OAuth redirects
CLIENT_URL=http://localhost:5173

# Where this server itself is reachable — Better Auth uses this to build OAuth callback URLs
BETTER_AUTH_URL=http://localhost:4000

# Random secrets — generate your own, e.g. `openssl rand -base64 32`. Never commit real values.
BETTER_AUTH_SECRET=replace-with-a-random-32-byte-string
SYNC_TICKET_SECRET=replace-with-a-different-random-32-byte-string

# LiveKit (self-hosted, via docker-compose.yml's livekit service, --dev mode)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Optional — only needed once you register OAuth apps with each provider.
# Leave blank/unset to disable that sign-in method; the app works fine with just email/password.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
